# Copy to .env (gitignored) and fill in real values before deploying.

DOMAIN_NAME=app.example.com

# Private registry (see docker/registry/) - requires `docker login` on this
# host first.
REGISTRY_URL=registry.example.com:5000
WEB_IMAGE_NAME=your-web-name
WEB_IMAGE_TAG=latest
APP_IMAGE_NAME=your-app-name
APP_IMAGE_TAG=latest

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
