# Copy to .env (gitignored) and fill in real values before deploying.

# Initial admin user, created via JCasC (no setup wizard).
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=change-me

# GID of the `docker` group on the host, so the jenkins user inside the
# container can use the mounted docker.sock. Get it with:
#   getent group docker | cut -d: -f3
DOCKER_GID=999
